groups:
  - name: Landscape Systemd Checks
    rules:
    - alert: Systemd Service landscape-api.service Down
      expr:  sum by (instance,juju_unit,juju_model,juju_application)  (node_systemd_unit_state{name="landscape-api.service", state="active"}) != count by (instance,juju_unit,juju_model,juju_application) (node_systemd_unit_state{name="landscape-api.service"} == 1)
      for: 30m
      labels:
        severity: low
        type: nrpe-replacement
        service: landscape-api
      annotations:
        summary: Landscape Systemd service landscape-api on {{ $labels.instance }} is down.
        description: |
          The systemd service "landscape-api.service" on {{ $labels.instance }} is down.
          Please check the unit and the logs.

    - alert: Systemd Service landscape-appserver.service Down
      expr:  sum by (instance,juju_unit,juju_model,juju_application)  (node_systemd_unit_state{name="landscape-appserver.service", state="active"}) != count by (instance,juju_unit,juju_model,juju_application) (node_systemd_unit_state{name="landscape-appserver.service"} == 1)
      for: 30m
      labels:
        severity: low
        type: nrpe-replacement
        service: landscape-appserver
      annotations:
        summary: Landscape Systemd service landscape-appserver on {{ $labels.instance }} is down.
