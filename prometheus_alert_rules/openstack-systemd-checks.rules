      for: 5m
      labels:
        severity: critical
        type: nrpe-replacement
        service: apache2
      annotations:
        summary: OpenStack Systemd service apache2 on {{ $labels.instance }} is down.
        description: |
          The systemd service "apache2.service" on {{ $labels.instance }} is down.
          This systemd unit could be part of any of the the following openstack components: aodh, ceph-radosgw, cinder, glance, heat, keystone, manila, neutron-api, nova-cloud-controller, octavia, openstack-dashboard.
          Please check the unit and the logs.

    - alert: Systemd Service ceilometer-agent-notification.service Down
