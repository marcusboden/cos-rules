groups:
  - name: OpenStack Systemd Checks
    rules:
    - alert: Systemd Service aodh-evaluator.service Down
      expr:  sum by (instance,juju_unit,juju_model,juju_application)  (node_systemd_unit_state{name="aodh-evaluator.service", state="active"}) != count by (instance,juju_unit,juju_model,juju_application) (node_systemd_unit_state{name="aodh-evaluator.service"} == 1)
      for: 5m
      labels:
        severity: critical
        type: nrpe-replacement
        service: aodh-evaluator
      annotations:
        summary: OpenStack Systemd service aodh-evaluator on {{ $labels.instance }} is down.
        description: |
          The systemd service "aodh-evaluator.service" on {{ $labels.instance }} is down.
          This systemd unit could be part of any of the the following openstack components: aodh.
          Please check the unit and the logs.

    - alert: Systemd Service aodh-listener.service Down
      expr:  sum by (instance,juju_unit,juju_model,juju_application)  (node_systemd_unit_state{name="aodh-listener.service", state="active"}) != count by (instance,juju_unit,juju_model,juju_application) (node_systemd_unit_state{name="aodh-listener.service"} == 1)
      for: 5m
      labels:
        severity: critical
        type: nrpe-replacement
        service: aodh-listener
      annotations:
        summary: OpenStack Systemd service aodh-listener on {{ $labels.instance }} is down.
        description: |
          The systemd service "aodh-listener.service" on {{ $labels.instance }} is down.
          This systemd unit could be part of any of the the following openstack components: aodh.
          Please check the unit and the logs.

    - alert: Systemd Service aodh-notifier.service Down
